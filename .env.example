# Telegram 通知 (可选 — 不填则静默禁用)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 企业微信群机器人 Webhook (可选 — 不填则静默禁用)
WECHAT_WEBHOOK_URL=

# 轮询间隔 (秒)
POLL_INTERVAL=600

# 默认标的 (逗号分隔)
SYMBOLS=USO,XOM,XLE,CRM

# 只推送强信号 (true/false)
STRONG_ONLY=false

# Ollama AI 解读 (可选 — 不填则 AI 功能禁用)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# Alpaca Paper Trading (可选 — 不填则交易功能禁用)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# API 安全 (可选 — 不开启则所有端点公开访问)
API_AUTH_ENABLED=false
API_KEYS=

# 速率限制
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_KEY_PER_MINUTE=120

# 日志格式 (console=开发, json=生产)
LOG_FORMAT=console
